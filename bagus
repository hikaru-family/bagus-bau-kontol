<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Welcome</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Poppins',sans-serif;
    height:100vh;
    overflow:hidden;
    display:flex;
    justify-content:center;
    align-items:center;
    background:
    linear-gradient(-45deg,#0f172a,#1e3a8a,#312e81,#111827);
    background-size:400% 400%;
    animation:bg 12s ease infinite;
    color:white;
}

@keyframes bg{
    0%{
        background-position:0% 50%;
    }
    50%{
        background-position:100% 50%;
    }
    100%{
        background-position:0% 50%;
    }
}

.container{
    text-align:center;
    background:rgba(255,255,255,0.08);
    border:1px solid rgba(255,255,255,0.1);
    backdrop-filter:blur(20px);
    padding:70px 50px;
    border-radius:30px;
    box-shadow:0 10px 40px rgba(0,0,0,0.4);
    width:90%;
    max-width:700px;
    animation:fade 1.2s ease;
}

@keyframes fade{
    from{
        opacity:0;
        transform:translateY(30px);
    }
    to{
        opacity:1;
        transform:translateY(0);
    }
}

.logo{
    font-size:60px;
    margin-bottom:20px;
}

h1{
    font-size:55px;
    margin-bottom:20px;
    background:linear-gradient(to right,#38bdf8,#8b5cf6,#ec4899);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

p{
    font-size:20px;
    color:#cbd5e1;
    margin-bottom:40px;
}

button{
    padding:16px 45px;
    border:none;
    border-radius:50px;
    font-size:18px;
    font-weight:600;
    cursor:pointer;
    color:white;
    background:linear-gradient(45deg,#3b82f6,#8b5cf6);
    transition:0.3s;
    box-shadow:0 0 25px rgba(99,102,241,0.5);
}

button:hover{
    transform:scale(1.08);
}

#hasil{
    display:none;
    margin-top:40px;
    font-size:50px;
    font-weight:700;
    background:linear-gradient(to right,#facc15,#fb7185,#38bdf8);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
    animation:muncul 1s ease;
}

@keyframes muncul{
    from{
        opacity:0;
        transform:scale(0.5);
    }
    to{
        opacity:1;
        transform:scale(1);
    }
}

@media(max-width:768px){

    h1{
        font-size:38px;
    }

    #hasil{
        font-size:35px;
    }

    p{
        font-size:16px;
    }

}

</style>
</head>

<body>

<div class="container">

    <div class="logo">🚀</div>

    <h1>WELCOME TO MY WEBSITE</h1>

    <p>
        Klik tombol masuk untuk melihat pesan rahasia ✨
    </p>

    <button onclick="masukWebsite()">
        MASUK
    </button>

    <div id="hasil">
        bagus bau 😎
    </div>

</div>

<script>

function masukWebsite(){

    document.getElementById("hasil").style.display = "block";

}

</script>

</body>
</html>
