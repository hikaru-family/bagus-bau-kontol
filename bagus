<!DOCTYPE html>
<html lang="id">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Miftahul Khoiri Ahmad</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

body{
    font-family:'Poppins',sans-serif;
    min-height:100vh;
    background:
    radial-gradient(circle at top left,#1e3a8a,#0f172a 40%),
    radial-gradient(circle at bottom right,#312e81,#020617 50%);
    color:white;
    overflow:hidden;
    position:relative;
}

/* ANIMASI BACKGROUND */
body::before{
    content:"";
    position:absolute;
    width:500px;
    height:500px;
    background:#3b82f6;
    filter:blur(150px);
    opacity:0.25;
    top:-100px;
    left:-100px;
    animation:gerak 10s infinite alternate;
}

body::after{
    content:"";
    position:absolute;
    width:400px;
    height:400px;
    background:#8b5cf6;
    filter:blur(150px);
    opacity:0.25;
    bottom:-100px;
    right:-100px;
    animation:gerak2 12s infinite alternate;
}

@keyframes gerak{
    from{
        transform:translate(0,0);
    }
    to{
        transform:translate(100px,50px);
    }
}

@keyframes gerak2{
    from{
        transform:translate(0,0);
    }
    to{
        transform:translate(-80px,-50px);
    }
}

.container{
    position:relative;
    z-index:2;
    width:90%;
    max-width:850px;
    margin:auto;
    top:50%;
    transform:translateY(-50%);
    text-align:center;
    background:rgba(255,255,255,0.08);
    border:1px solid rgba(255,255,255,0.1);
    backdrop-filter:blur(20px);
    border-radius:30px;
    padding:70px 50px;
    box-shadow:0 15px 40px rgba(0,0,0,0.4);
    animation:fade 1.5s ease;
}

.profile{
    width:140px;
    height:140px;
    border-radius:50%;
    object-fit:cover;
    border:4px solid rgba(255,255,255,0.2);
    margin-bottom:25px;
    box-shadow:0 0 30px rgba(59,130,246,0.5);
}

h1{
    font-size:58px;
    margin-bottom:15px;
    background:linear-gradient(to right,#60a5fa,#a78bfa);
    -webkit-background-clip:text;
    -webkit-text-fill-color:transparent;
}

.subtitle{
    font-size:22px;
    color:#cbd5e1;
    margin-bottom:35px;
}

.desc{
    font-size:18px;
    color:#e2e8f0;
    line-height:1.9;
    max-width:650px;
    margin:auto;
}

.btn-group{
    margin-top:45px;
    display:flex;
    justify-content:center;
    gap:20px;
    flex-wrap:wrap;
}

.btn{
    text-decoration:none;
    padding:15px 35px;
    border-radius:50px;
    font-size:17px;
    font-weight:600;
    transition:0.3s;
}

.btn-primary{
    background:linear-gradient(45deg,#3b82f6,#8b5cf6);
    color:white;
    box-shadow:0 0 25px rgba(99,102,241,0.4);
}

.btn-primary:hover{
    transform:translateY(-5px) scale(1.05);
}

.btn-secondary{
    border:1px solid rgba(255,255,255,0.2);
    color:white;
    background:rgba(255,255,255,0.05);
}

.btn-secondary:hover{
    background:rgba(255,255,255,0.1);
    transform:translateY(-5px);
}

.socials{
    margin-top:40px;
    display:flex;
    justify-content:center;
    gap:20px;
    font-size:28px;
}

.socials a{
    color:white;
    transition:0.3s;
}

.socials a:hover{
    color:#60a5fa;
    transform:scale(1.2);
}

@keyframes fade{
    from{
        opacity:0;
        transform:translateY(50px);
    }
    to{
        opacity:1;
        transform:translateY(-50%);
    }
}

@media(max-width:768px){

    h1{
        font-size:42px;
    }

    .subtitle{
        font-size:18px;
    }

    .desc{
        font-size:16px;
    }

    .container{
        padding:50px 25px;
    }

}

</style>
</head>

<body>

<div class="container">

    <img 
    class="profile"
    src="https://i.imgur.com/2DhmtJ4.png"
    alt="profile">

    <h1>Miftahul Khoiri Ahmad</h1>

    <div class="subtitle">
        Digital Creator • Developer • Content Strategist
    </div>

    <p class="desc">
        Selamat datang di website personal saya ✨ <br>
        Tempat berbagi project kreatif, pengembangan digital,
        dan perjalanan membangun ide menjadi sesuatu yang luar biasa.
    </p>

    <div class="btn-group">
        <a href="#" class="btn btn-primary">Explore Project</a>
        <a href="#" class="btn btn-secondary">Contact Me</a>
    </div>

    <div class="socials">
        <a href="#">🌐</a>
        <a href="#">📸</a>
        <a href="#">🎵</a>
        <a href="#">💻</a>
    </div>

</div>

</body>
</html>
